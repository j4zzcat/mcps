{
  "name": "ufoevidence-mcp",
  "version": "0.1.0",
  "description": "Read-only MCP server for UFOevidence.com case evidence and scoring data.",
  "type": "module",
  "bin": {
    "ufoevidence-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc --noEmit false",
    "dev": "tsx src/index.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-sqlite3": "^12.10.0",
    "cheerio": "^1.0.0",
    "undici": "^7.10.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.0",
    "eslint": "^9.28.0",
    "prettier": "^3.5.0",
    "prisma": "^7.8.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.33.0",
    "vitest": "^4.1.8"
  }
}
